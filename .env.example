# === Database: Turso (libSQL) ===
# Create a free Turso DB: turso db create grabpic-dev
# Get credentials: turso db show grabpic-dev
TURSO_URL=libsql://grabpic-dev.turso.io
TURSO_TOKEN=

# === Cloudflare R2 (Photo Storage) ===
# Create R2 bucket: wrangler r2 bucket create grabpic-photos
# Generate API keys from Cloudflare Dashboard > R2 > Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET_NAME=grabpic-photos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# === Cloudflare Workers (API Deployment) ===
# Get from Cloudflare Dashboard > API Tokens
CLOUDFLARE_API_TOKEN=

# === Modal.com (GPU ML Processing) ===
# Setup: pip install modal && modal setup && modal token new
MODAL_TOKEN=
MODAL_WEBHOOK_URL=

# === API Base URL ===
# Use http://localhost:8787 for local dev with wrangler dev
# Use the deployed Worker URL for production
API_BASE_URL=http://localhost:8787

# === Frontend ===
# Next.js public env var for API URL (client-side accessible)
NEXT_PUBLIC_API_URL=http://localhost:8787

# === Monitoring & Analytics (Optional) ===
SENTRY_DSN=
POSTHOG_API_KEY=

# === JWT Secret (Future: Organizer Auth) ===
JWT_SECRET=
